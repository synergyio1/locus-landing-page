{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0166DDXQkD7YM94T252S82Ec","type":"tool_result","content":"1\texport type CheckoutCadence = \"monthly\" | \"yearly\"\n2\t\n3\texport type StartCheckoutResult =\n4\t  | { kind: \"ok\"; url: string }\n5\t  | { kind: \"price_not_configured\" }\n6\t  | { kind: \"malformed_response\" }\n7\t  | { kind: \"network_error\" }\n8\t  | { kind: \"http_error\"; status: number }\n9\t\n10\texport async function startCheckout(\n11\t  cadence: CheckoutCadence\n12\t): Promise<StartCheckoutResult> {\n13\t  let response: Response\n14\t  try {\n15\t    response = await fetch(\"/api/checkout/create\", {\n16\t      method: \"POST\",\n17\t      headers: { \"Content-Type\": \"application/json\" },\n18\t      body: JSON.stringify({ priceId: cadence }),\n19\t    })\n20\t  } catch {\n21\t    return { kind: \"network_error\" }\n22\t  }\n23\t\n24\t  if (!response.ok) {\n25\t    const body = (await response.json().catch(() => null)) as {\n26\t      error?: string\n27\t    } | null\n28\t    if (body?.error === \"price_not_configured\") {\n29\t      return { kind: \"price_not_configured\" }\n30\t    }\n31\t    return { kind: \"http_error\", status: response.status }\n32\t  }\n33\t\n34\t  let body: unknown\n35\t  try {\n36\t    body = await response.json()\n37\t  } catch {\n38\t    return { kind: \"malformed_response\" }\n39\t  }\n40\t\n41\t  const url = (body as { url?: unknown } | null)?.url\n42\t  if (typeof url !== \"string\" || url.length === 0) {\n43\t    return { kind: \"malformed_response\" }\n44\t  }\n45\t\n46\t  return { kind: \"ok\", url }\n47\t}\n48\t"}]},"parent_tool_use_id":null,"session_id":"27f26790-1c77-48bd-8a91-2b53cecc1231","uuid":"f9473fb9-ab7e-45d8-b3a7-718fc88b5a13","timestamp":"2026-04-28T13:38:58.286Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/cippa/Desktop/fly/locus-landing-page-preview/src/lib/billing/start-checkout.ts","content":"export type CheckoutCadence = \"monthly\" | \"yearly\"\n\nexport type StartCheckoutResult =\n  | { kind: \"ok\"; url: string }\n  | { kind: \"price_not_configured\" }\n  | { kind: \"malformed_response\" }\n  | { kind: \"network_error\" }\n  | { kind: \"http_error\"; status: number }\n\nexport async function startCheckout(\n  cadence: CheckoutCadence\n): Promise<StartCheckoutResult> {\n  let response: Response\n  try {\n    response = await fetch(\"/api/checkout/create\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ priceId: cadence }),\n    })\n  } catch {\n    return { kind: \"network_error\" }\n  }\n\n  if (!response.ok) {\n    const body = (await response.json().catch(() => null)) as {\n      error?: string\n    } | null\n    if (body?.error === \"price_not_configured\") {\n      return { kind: \"price_not_configured\" }\n    }\n    return { kind: \"http_error\", status: response.status }\n  }\n\n  let body: unknown\n  try {\n    body = await response.json()\n  } catch {\n    return { kind: \"malformed_response\" }\n  }\n\n  const url = (body as { url?: unknown } | null)?.url\n  if (typeof url !== \"string\" || url.length === 0) {\n    return { kind: \"malformed_response\" }\n  }\n\n  return { kind: \"ok\", url }\n}\n","numLines":48,"startLine":1,"totalLines":48}}}
