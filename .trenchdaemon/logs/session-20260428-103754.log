{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WgimyqmfNsh6kVZXrUK5wn","type":"tool_result","content":"1\t\"use client\"\n2\t\n3\timport * as React from \"react\"\n4\timport Link from \"next/link\"\n5\timport { LayoutGroup, motion, useMotionValueEvent, useScroll } from \"motion/react\"\n6\t\n7\timport { AccountMenu } from \"@/components/account-menu\"\n8\timport { buttonVariants } from \"@/components/ui/button\"\n9\timport { Logo } from \"@/components/ui/logo\"\n10\timport { MagneticButton } from \"@/components/ui/magnetic-button\"\n11\timport { signOutAction } from \"@/lib/auth/sign-out\"\n12\timport { cn } from \"@/lib/utils\"\n13\t\n14\ttype NavItem = { href: string; label: string }\n15\t\n16\tconst NAV_ITEMS: NavItem[] = [\n17\t  { href: \"/#day-in-locus\", label: \"How it works\" },\n18\t  { href: \"/pricing\", label: \"Pricing\" },\n19\t  { href: \"/changelog\", label: \"Changelog\" },\n20\t]\n21\t\n22\ttype SiteNavClientProps = {\n23\t  email: string | null\n24\t}\n25\t\n26\texport function SiteNavClient({ email }: SiteNavClientProps) {\n27\t  const [open, setOpen] = React.useState(false)\n28\t  const [compact, setCompact] = React.useState(false)\n29\t  const { scrollY } = useScroll()\n30\t  const isAuthed = email !== null\n31\t\n32\t  useMotionValueEvent(scrollY, \"change\", (value) => {\n33\t    setCompact(value > 80)\n34\t  })\n35\t\n36\t  React.useEffect(() => {\n37\t    if (!open) return\n38\t    const onKey = (e: KeyboardEvent) => {\n39\t      if (e.key === \"Escape\") setOpen(false)\n40\t    }\n41\t    window.addEventListener(\"keydown\", onKey)\n42\t    document.body.style.overflow = \"hidden\"\n43\t    return () => {\n44\t      window.removeEventListener(\"keydown\", onKey)\n45\t      document.body.style.overflow = \"\"\n46\t    }\n47\t  }, [open])\n48\t\n49\t  return (\n50\t    <header\n51\t      data-slot=\"site-nav\"\n52\t      className=\"sticky top-3 z-50 w-full md:top-5\"\n53\t    >\n54\t      <div className=\"mx-auto flex max-w-[720px] items-center justify-center px-4\">\n55\t        <motion.div\n56\t          layout\n57\t          transition={{ type: \"spring\", stiffness: 320, damping: 30 }}\n58\t          data-compact={compact ? \"true\" : \"false\"}\n59\t          className={cn(\n60\t            \"relative flex w-full items-center justify-between gap-4 rounded-full border border-[var(--border)] backdrop-blur-xl transition-[padding,background-color] duration-200\",\n61\t            \"shadow-[0_10px_30px_-15px_rgba(0,0,0,0.7),inset_0_1px_0_rgba(255,255,255,0.06)]\",\n62\t            compact\n63\t              ? \"bg-[color-mix(in_oklab,var(--bg)_94%,transparent)] backdrop-saturate-150 px-3 py-1.5\"\n64\t              : \"bg-[color-mix(in_oklab,var(--bg)_72%,transparent)] px-4 py-2\"\n65\t          )}\n66\t        >\n67\t          <Link\n68\t            href=\"/\"\n69\t            aria-label=\"Locus home\"\n70\t            className=\"inline-flex items-center gap-2 pl-1 font-semibold tracking-tight text-[var(--fg)]\"\n71\t          >\n72\t            <Logo size={18} />\n73\t            <span className={cn(\"text-sm\", compact ? \"sr-only md:not-sr-only\" : \"\")}>Locus</span>\n74\t          </Link>\n75\t\n76\t          <LayoutGroup id=\"site-nav-hover\">\n77\t            <nav\n78\t              aria-label=\"Primary\"\n79\t              className=\"hidden items-center gap-0.5 md:flex\"\n80\t            >\n81\t              {NAV_ITEMS.map((item) => (\n82\t                <NavHoverLink key={item.href} item={item} />\n83\t              ))}\n84\t            </nav>\n85\t          </LayoutGroup>\n86\t\n87\t          <div className=\"flex items-center gap-1.5\">\n88\t            {isAuthed ? (\n89\t              <AccountMenu email={email} className=\"hidden md:block\" />\n90\t            ) : (\n91\t              <MagneticButton href=\"/download\" className=\"hidden md:inline-flex\">\n92\t                <span className={cn(buttonVariants({ size: \"sm\" }))}>Download</span>\n93\t              </MagneticButton>\n94\t            )}\n95\t            <MobileToggle open={open} onToggle={() => setOpen((v) => !v)} />\n96\t          </div>\n97\t        </motion.div>\n98\t      </div>\n99\t\n100\t      <MobileSheet\n101\t        open={open}\n102\t        onClose={() => setOpen(false)}\n103\t        isAuthed={isAuthed}\n104\t      />\n105\t    </header>\n106\t  )\n107\t}\n108\t\n109\tfunction NavHoverLink({ item }: { item: NavItem }) {\n110\t  const [hover, setHover] = React.useState(false)\n111\t  return (\n112\t    <Link\n113\t      href={item.href}\n114\t      onPointerEnter={() => setHover(true)}\n115\t      onPointerLeave={() => setHover(false)}\n116\t      onFocus={() => setHover(true)}\n117\t      onBlur={() => setHover(false)}\n118\t      className=\"relative rounded-full px-3 py-1.5 text-sm text-[var(--muted-foreground)] transition-colors hover:text-[var(--fg)]\"\n119\t    >\n120\t      {hover ? (\n121\t        <motion.span\n122\t          layoutId=\"site-nav-hover-pill\"\n123\t          transition={{ type: \"spring\", stiffness: 420, damping: 32 }}\n124\t          className=\"absolute inset-0 rounded-full bg-[var(--surface-raised)]\"\n125\t        />\n126\t      ) : null}\n127\t      <span className=\"relative\">{item.label}</span>\n128\t    </Link>\n129\t  )\n130\t}\n131\t\n132\tfunction MobileToggle({\n133\t  open,\n134\t  onToggle,\n135\t}: {\n136\t  open: boolean\n137\t  onToggle: () => void\n138\t}) {\n139\t  return (\n140\t    <button\n141\t      type=\"button\"\n142\t      aria-label={open ? \"Close menu\" : \"Open menu\"}\n143\t      aria-expanded={open}\n144\t      aria-controls=\"site-nav-sheet\"\n145\t      onClick={onToggle}\n146\t      className=\"inline-flex size-8 items-center justify-center rounded-full text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)] md:hidden\"\n147\t    >\n148\t      <span className=\"sr-only\">{open ? \"Close menu\" : \"Open menu\"}</span>\n149\t      <svg\n150\t        aria-hidden\n151\t        viewBox=\"0 0 20 20\"\n152\t        fill=\"none\"\n153\t        className=\"size-5\"\n154\t        stroke=\"currentColor\"\n155\t        strokeWidth=\"1.6\"\n156\t        strokeLinecap=\"round\"\n157\t      >\n158\t        {open ? (\n159\t          <>\n160\t            <path d=\"M5 5l10 10\" />\n161\t            <path d=\"M15 5L5 15\" />\n162\t          </>\n163\t        ) : (\n164\t          <>\n165\t            <path d=\"M3 7h14\" />\n166\t            <path d=\"M3 13h14\" />\n167\t          </>\n168\t        )}\n169\t      </svg>\n170\t    </button>\n171\t  )\n172\t}\n173\t\n174\tfunction MobileSheet({\n175\t  open,\n176\t  onClose,\n177\t  isAuthed,\n178\t}: {\n179\t  open: boolean\n180\t  onClose: () => void\n181\t  isAuthed: boolean\n182\t}) {\n183\t  return (\n184\t    <div\n185\t      id=\"site-nav-sheet\"\n186\t      data-state={open ? \"open\" : \"closed\"}\n187\t      className={cn(\n188\t        \"fixed inset-x-0 top-14 z-40 mx-4 overflow-hidden rounded-2xl border border-[var(--border)] bg-[color-mix(in_oklab,var(--bg)_95%,transparent)] backdrop-blur-xl transition-[opacity,transform] duration-200 md:hidden\",\n189\t        open\n190\t          ? \"pointer-events-auto translate-y-0 opacity-100\"\n191\t          : \"pointer-events-none -translate-y-2 opacity-0\"\n192\t      )}\n193\t      aria-hidden={!open}\n194\t    >\n195\t      <div className=\"p-4\">\n196\t        <nav aria-label=\"Mobile\" className=\"flex flex-col gap-1\">\n197\t          {NAV_ITEMS.map((item) => (\n198\t            <Link\n199\t              key={item.href}\n200\t              href={item.href}\n201\t              onClick={onClose}\n202\t              className=\"rounded-md px-3 py-3 text-base text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)]\"\n203\t            >\n204\t              {item.label}\n205\t            </Link>\n206\t          ))}\n207\t          {isAuthed ? (\n208\t            <>\n209\t              <Link\n210\t                href=\"/account\"\n211\t                onClick={onClose}\n212\t                className=\"rounded-md px-3 py-3 text-base text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)]\"\n213\t              >\n214\t                Account\n215\t              </Link>\n216\t              <form action={signOutAction}>\n217\t                <button\n218\t                  type=\"submit\"\n219\t                  className=\"w-full rounded-md px-3 py-3 text-left text-base text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)]\"\n220\t                >\n221\t                  Log out\n222\t                </button>\n223\t              </form>\n224\t            </>\n225\t          ) : null}\n226\t        </nav>\n227\t        {!isAuthed ? (\n228\t          <Link\n229\t            href=\"/download\"\n230\t            onClick={onClose}\n231\t            className={cn(buttonVariants({ size: \"lg\" }), \"mt-3 w-full\")}\n232\t          >\n233\t            Download for macOS\n234\t          </Link>\n235\t        ) : null}\n236\t      </div>\n237\t    </div>\n238\t  )\n239\t}\n240\t"}]},"parent_tool_use_id":null,"session_id":"27f26790-1c77-48bd-8a91-2b53cecc1231","uuid":"51b5419e-edad-4ef6-a650-104ab0d4703f","timestamp":"2026-04-28T13:39:31.902Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/cippa/Desktop/fly/locus-landing-page-preview/src/components/site-nav-client.tsx","content":"\"use client\"\n\nimport * as React from \"react\"\nimport Link from \"next/link\"\nimport { LayoutGroup, motion, useMotionValueEvent, useScroll } from \"motion/react\"\n\nimport { AccountMenu } from \"@/components/account-menu\"\nimport { buttonVariants } from \"@/components/ui/button\"\nimport { Logo } from \"@/components/ui/logo\"\nimport { MagneticButton } from \"@/components/ui/magnetic-button\"\nimport { signOutAction } from \"@/lib/auth/sign-out\"\nimport { cn } from \"@/lib/utils\"\n\ntype NavItem = { href: string; label: string }\n\nconst NAV_ITEMS: NavItem[] = [\n  { href: \"/#day-in-locus\", label: \"How it works\" },\n  { href: \"/pricing\", label: \"Pricing\" },\n  { href: \"/changelog\", label: \"Changelog\" },\n]\n\ntype SiteNavClientProps = {\n  email: string | null\n}\n\nexport function SiteNavClient({ email }: SiteNavClientProps) {\n  const [open, setOpen] = React.useState(false)\n  const [compact, setCompact] = React.useState(false)\n  const { scrollY } = useScroll()\n  const isAuthed = email !== null\n\n  useMotionValueEvent(scrollY, \"change\", (value) => {\n    setCompact(value > 80)\n  })\n\n  React.useEffect(() => {\n    if (!open) return\n    const onKey = (e: KeyboardEvent) => {\n      if (e.key === \"Escape\") setOpen(false)\n    }\n    window.addEventListener(\"keydown\", onKey)\n    document.body.style.overflow = \"hidden\"\n    return () => {\n      window.removeEventListener(\"keydown\", onKey)\n      document.body.style.overflow = \"\"\n    }\n  }, [open])\n\n  return (\n    <header\n      data-slot=\"site-nav\"\n      className=\"sticky top-3 z-50 w-full md:top-5\"\n    >\n      <div className=\"mx-auto flex max-w-[720px] items-center justify-center px-4\">\n        <motion.div\n          layout\n          transition={{ type: \"spring\", stiffness: 320, damping: 30 }}\n          data-compact={compact ? \"true\" : \"false\"}\n          className={cn(\n            \"relative flex w-full items-center justify-between gap-4 rounded-full border border-[var(--border)] backdrop-blur-xl transition-[padding,background-color] duration-200\",\n            \"shadow-[0_10px_30px_-15px_rgba(0,0,0,0.7),inset_0_1px_0_rgba(255,255,255,0.06)]\",\n            compact\n              ? \"bg-[color-mix(in_oklab,var(--bg)_94%,transparent)] backdrop-saturate-150 px-3 py-1.5\"\n              : \"bg-[color-mix(in_oklab,var(--bg)_72%,transparent)] px-4 py-2\"\n          )}\n        >\n          <Link\n            href=\"/\"\n            aria-label=\"Locus home\"\n            className=\"inline-flex items-center gap-2 pl-1 font-semibold tracking-tight text-[var(--fg)]\"\n          >\n            <Logo size={18} />\n            <span className={cn(\"text-sm\", compact ? \"sr-only md:not-sr-only\" : \"\")}>Locus</span>\n          </Link>\n\n          <LayoutGroup id=\"site-nav-hover\">\n            <nav\n              aria-label=\"Primary\"\n              className=\"hidden items-center gap-0.5 md:flex\"\n            >\n              {NAV_ITEMS.map((item) => (\n                <NavHoverLink key={item.href} item={item} />\n              ))}\n            </nav>\n          </LayoutGroup>\n\n          <div className=\"flex items-center gap-1.5\">\n            {isAuthed ? (\n              <AccountMenu email={email} className=\"hidden md:block\" />\n            ) : (\n              <MagneticButton href=\"/download\" className=\"hidden md:inline-flex\">\n                <span className={cn(buttonVariants({ size: \"sm\" }))}>Download</span>\n              </MagneticButton>\n            )}\n            <MobileToggle open={open} onToggle={() => setOpen((v) => !v)} />\n          </div>\n        </motion.div>\n      </div>\n\n      <MobileSheet\n        open={open}\n        onClose={() => setOpen(false)}\n        isAuthed={isAuthed}\n      />\n    </header>\n  )\n}\n\nfunction NavHoverLink({ item }: { item: NavItem }) {\n  const [hover, setHover] = React.useState(false)\n  return (\n    <Link\n      href={item.href}\n      onPointerEnter={() => setHover(true)}\n      onPointerLeave={() => setHover(false)}\n      onFocus={() => setHover(true)}\n      onBlur={() => setHover(false)}\n      className=\"relative rounded-full px-3 py-1.5 text-sm text-[var(--muted-foreground)] transition-colors hover:text-[var(--fg)]\"\n    >\n      {hover ? (\n        <motion.span\n          layoutId=\"site-nav-hover-pill\"\n          transition={{ type: \"spring\", stiffness: 420, damping: 32 }}\n          className=\"absolute inset-0 rounded-full bg-[var(--surface-raised)]\"\n        />\n      ) : null}\n      <span className=\"relative\">{item.label}</span>\n    </Link>\n  )\n}\n\nfunction MobileToggle({\n  open,\n  onToggle,\n}: {\n  open: boolean\n  onToggle: () => void\n}) {\n  return (\n    <button\n      type=\"button\"\n      aria-label={open ? \"Close menu\" : \"Open menu\"}\n      aria-expanded={open}\n      aria-controls=\"site-nav-sheet\"\n      onClick={onToggle}\n      className=\"inline-flex size-8 items-center justify-center rounded-full text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)] md:hidden\"\n    >\n      <span className=\"sr-only\">{open ? \"Close menu\" : \"Open menu\"}</span>\n      <svg\n        aria-hidden\n        viewBox=\"0 0 20 20\"\n        fill=\"none\"\n        className=\"size-5\"\n        stroke=\"currentColor\"\n        strokeWidth=\"1.6\"\n        strokeLinecap=\"round\"\n      >\n        {open ? (\n          <>\n            <path d=\"M5 5l10 10\" />\n            <path d=\"M15 5L5 15\" />\n          </>\n        ) : (\n          <>\n            <path d=\"M3 7h14\" />\n            <path d=\"M3 13h14\" />\n          </>\n        )}\n      </svg>\n    </button>\n  )\n}\n\nfunction MobileSheet({\n  open,\n  onClose,\n  isAuthed,\n}: {\n  open: boolean\n  onClose: () => void\n  isAuthed: boolean\n}) {\n  return (\n    <div\n      id=\"site-nav-sheet\"\n      data-state={open ? \"open\" : \"closed\"}\n      className={cn(\n        \"fixed inset-x-0 top-14 z-40 mx-4 overflow-hidden rounded-2xl border border-[var(--border)] bg-[color-mix(in_oklab,var(--bg)_95%,transparent)] backdrop-blur-xl transition-[opacity,transform] duration-200 md:hidden\",\n        open\n          ? \"pointer-events-auto translate-y-0 opacity-100\"\n          : \"pointer-events-none -translate-y-2 opacity-0\"\n      )}\n      aria-hidden={!open}\n    >\n      <div className=\"p-4\">\n        <nav aria-label=\"Mobile\" className=\"flex flex-col gap-1\">\n          {NAV_ITEMS.map((item) => (\n            <Link\n              key={item.href}\n              href={item.href}\n              onClick={onClose}\n              className=\"rounded-md px-3 py-3 text-base text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)]\"\n            >\n              {item.label}\n            </Link>\n          ))}\n          {isAuthed ? (\n            <>\n              <Link\n                href=\"/account\"\n                onClick={onClose}\n                className=\"rounded-md px-3 py-3 text-base text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)]\"\n              >\n                Account\n              </Link>\n              <form action={signOutAction}>\n                <button\n                  type=\"submit\"\n                  className=\"w-full rounded-md px-3 py-3 text-left text-base text-[var(--fg)] transition-colors hover:bg-[var(--surface-raised)]\"\n                >\n                  Log out\n                </button>\n              </form>\n            </>\n          ) : null}\n        </nav>\n        {!isAuthed ? (\n          <Link\n            href=\"/download\"\n            onClick={onClose}\n            className={cn(buttonVariants({ size: \"lg\" }), \"mt-3 w-full\")}\n          >\n            Download for macOS\n          </Link>\n        ) : null}\n      </div>\n    </div>\n  )\n}\n","numLines":240,"startLine":1,"totalLines":240}}}
