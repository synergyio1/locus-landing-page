{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012o3kKn4m7kfq7iLa5M88Hd","type":"tool_result","content":"1\timport { redirect } from \"next/navigation\"\n2\t\n3\timport { createServerClient } from \"@/lib/supabase/server\"\n4\t\n5\timport { LoginForm } from \"./login-form\"\n6\t\n7\ttype PageProps = {\n8\t  searchParams: Promise<{ next?: string; error?: string; notice?: string }>\n9\t}\n10\t\n11\tfunction sanitizeNext(next: string | undefined): string {\n12\t  if (!next) return \"/account\"\n13\t  if (!next.startsWith(\"/\") || next.startsWith(\"//\")) return \"/account\"\n14\t  return next\n15\t}\n16\t\n17\tfunction errorMessageFor(code: string | undefined): string | undefined {\n18\t  if (!code) return undefined\n19\t  if (code === \"missing_code\") return \"We couldn't complete your sign-in. Please try again.\"\n20\t  if (code === \"exchange_failed\") return \"That sign-in link is invalid or expired. Please try again.\"\n21\t  return \"Something went wrong. Please try again.\"\n22\t}\n23\t\n24\tfunction noticeMessageFor(code: string | undefined): string | undefined {\n25\t  if (code === \"signin\") return \"Please sign in to continue.\"\n26\t  return undefined\n27\t}\n28\t\n29\texport default async function LoginPage({ searchParams }: PageProps) {\n30\t  const { next, error, notice } = await searchParams\n31\t  const safeNext = sanitizeNext(next)\n32\t\n33\t  const supabase = await createServerClient()\n34\t  const {\n35\t    data: { user },\n36\t  } = await supabase.auth.getUser()\n37\t\n38\t  if (user) {\n39\t    redirect(safeNext)\n40\t  }\n41\t\n42\t  return (\n43\t    <section className=\"mx-auto max-w-md px-6 py-16\">\n44\t      <h1 className=\"text-3xl font-semibold tracking-tight\">Sign in to Locus</h1>\n45\t      <p className=\"mt-2 text-sm text-[var(--fg)]/60\">\n46\t        Welcome back — pick up where you left off.\n47\t      </p>\n48\t      <div className=\"mt-8\">\n49\t        <LoginForm\n50\t          next={safeNext}\n51\t          errorMessage={errorMessageFor(error)}\n52\t          noticeMessage={noticeMessageFor(notice)}\n53\t        />\n54\t      </div>\n55\t    </section>\n56\t  )\n57\t}\n58\t"}]},"parent_tool_use_id":null,"session_id":"27f26790-1c77-48bd-8a91-2b53cecc1231","uuid":"3d65d326-920e-4c74-93b3-16a2407eb97f","timestamp":"2026-04-28T13:38:52.938Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/cippa/Desktop/fly/locus-landing-page-preview/src/app/login/page.tsx","content":"import { redirect } from \"next/navigation\"\n\nimport { createServerClient } from \"@/lib/supabase/server\"\n\nimport { LoginForm } from \"./login-form\"\n\ntype PageProps = {\n  searchParams: Promise<{ next?: string; error?: string; notice?: string }>\n}\n\nfunction sanitizeNext(next: string | undefined): string {\n  if (!next) return \"/account\"\n  if (!next.startsWith(\"/\") || next.startsWith(\"//\")) return \"/account\"\n  return next\n}\n\nfunction errorMessageFor(code: string | undefined): string | undefined {\n  if (!code) return undefined\n  if (code === \"missing_code\") return \"We couldn't complete your sign-in. Please try again.\"\n  if (code === \"exchange_failed\") return \"That sign-in link is invalid or expired. Please try again.\"\n  return \"Something went wrong. Please try again.\"\n}\n\nfunction noticeMessageFor(code: string | undefined): string | undefined {\n  if (code === \"signin\") return \"Please sign in to continue.\"\n  return undefined\n}\n\nexport default async function LoginPage({ searchParams }: PageProps) {\n  const { next, error, notice } = await searchParams\n  const safeNext = sanitizeNext(next)\n\n  const supabase = await createServerClient()\n  const {\n    data: { user },\n  } = await supabase.auth.getUser()\n\n  if (user) {\n    redirect(safeNext)\n  }\n\n  return (\n    <section className=\"mx-auto max-w-md px-6 py-16\">\n      <h1 className=\"text-3xl font-semibold tracking-tight\">Sign in to Locus</h1>\n      <p className=\"mt-2 text-sm text-[var(--fg)]/60\">\n        Welcome back — pick up where you left off.\n      </p>\n      <div className=\"mt-8\">\n        <LoginForm\n          next={safeNext}\n          errorMessage={errorMessageFor(error)}\n          noticeMessage={noticeMessageFor(notice)}\n        />\n      </div>\n    </section>\n  )\n}\n","numLines":58,"startLine":1,"totalLines":58}}}
