 error: \"checkout_failed\" }), {\n54\t        status: 500,\n55\t        headers: { \"Content-Type\": \"application/json\" },\n56\t      })\n57\t    )\n58\t\n59\t    const result = await startCheckout(\"monthly\")\n60\t\n61\t    expect(result).toEqual({ kind: \"http_error\", status: 500 })\n62\t  })\n63\t\n64\t  it(\"returns http_error when the non-2xx body is not JSON\", async () => {\n65\t    fetchMock.mockResolvedValue(\n66\t      new Response(\"<!doctype html>\", { status: 502 })\n67\t    )\n68\t\n69\t    const result = await startCheckout(\"monthly\")\n70\t\n71\t    expect(result).toEqual({ kind: \"http_error\", status: 502 })\n72\t  })\n73\t\n74\t  it(\"returns malformed_response when a 2xx body is not JSON\", async () => {\n75\t    fetchMock.mockResolvedValue(new Response(\"not json\", { status: 200 }))\n76\t\n77\t    const result = await startCheckout(\"monthly\")\n78\t\n79\t    expect(result).toEqual({ kind: \"malformed_response\" })\n80\t  })\n81\t\n82\t  it(\"returns malformed_response when a 2xx JSON body has no url field\", async () => {\n83\t    fetchMock.mockResolvedValue(\n84\t      new Response(JSON.stringify({}), {\n85\t        status: 200,\n86\t        headers: { \"Content-Type\": \"application/json\" },\n87\t      })\n88\t    )\n89\t\n90\t    const result = await startCheckout(\"monthly\")\n91\t\n92\t    expect(result).toEqual({ kind: \"malformed_response\" })\n93\t  })\n94\t\n95\t  it(\"returns network_error when fetch rejects\", async () => {\n96\t    fetchMock.mockRejectedValue(new TypeError(\"offline\"))\n97\t\n98\t    const result = await startCheckout(\"monthly\")\n99\t\n100\t    expect(result).toEqual({ kind: \"network_error\" })\n101\t  })\n102\t})\n103\t"}]},"parent_tool_use_id":null,"session_id":"27f26790-1c77-48bd-8a91-2b53cecc1231","uuid":"76386758-7c05-4ecf-a063-f7eed48cccdf","timestamp":"2026-04-28T13:39:01.016Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/cippa/Desktop/fly/locus-landing-page-preview/src/lib/billing/